---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import TOC from "../../../components/TOC.astro";
import { getCollection, render, type CollectionEntry } from "astro:content";

interface NavPost {
  title: string;
  href: string;
}

interface Props {
  post: CollectionEntry<"blog">;
  prev: NavPost | null;
  next: NavPost | null;
}

export async function getStaticPaths() {
  const posts = (await getCollection("blog", (entry) => entry.data.lang === "en" && !entry.data.draft)).sort(
    (a, b) => b.data.date.getTime() - a.data.date.getTime()
  );

  return posts.map((post, index) => {
    const localSlug = post.slug.replace(/^en\//, "");

    const prevPost = posts[index + 1];
    const nextPost = posts[index - 1];

    return {
      params: { slug: localSlug },
      props: {
        post,
        prev: prevPost
          ? {
              title: prevPost.data.title,
              href: `/en/blog/${prevPost.slug.replace(/^en\//, "")}/`
            }
          : null,
        next: nextPost
          ? {
              title: nextPost.data.title,
              href: `/en/blog/${nextPost.slug.replace(/^en\//, "")}/`
            }
          : null
      }
    };
  });
}

const { post, prev, next } = Astro.props;
const { Content, headings } = await render(post);
---
<BaseLayout lang="en" title={`${post.data.title} | Zifeng Xiong`} description={post.data.description}>
  <section class="section">
    <div class="container post-layout">
      <TOC lang="en" headings={headings} />

      <article class="post-body">
        <p class="meta-line">{post.data.date.toISOString().slice(0, 10)}</p>
        <h1>{post.data.title}</h1>
        <p>{post.data.description}</p>

        <div class="post-meta">
          {post.data.tags.map((tag) => (
            <span>{tag}</span>
          ))}
        </div>

        <hr style="border:none;border-top:1px solid var(--line);margin:18px 0;" />
        <Content />

        <div class="post-nav">
          {prev ? <a href={prev.href}>&lt; Prev: {prev.title}</a> : <span></span>}
          {next ? <a href={next.href}>Next: {next.title} &gt;</a> : <span></span>}
        </div>
      </article>
    </div>
  </section>
</BaseLayout>
