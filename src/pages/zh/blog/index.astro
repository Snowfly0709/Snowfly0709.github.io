---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import BlogIndexPage from "../../../components/BlogIndexPage.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog", (entry) => entry.data.lang === "zh" && !entry.data.draft)).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);
---
<BaseLayout lang="zh" title="博客 | 熊子枫" description="熊子枫的技术笔记与产品思考。">
  <BlogIndexPage lang="zh" posts={posts} />
</BaseLayout>
