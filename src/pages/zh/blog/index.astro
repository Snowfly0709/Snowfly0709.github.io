---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import BlogIndexPage from "../../../components/BlogIndexPage.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog", (entry) => entry.data.lang === "zh" && !entry.data.draft)).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);
---
<BaseLayout lang="zh" title="๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ | ๏ฟฝ๏ฟฝ๏ฟฝำท๏ฟฝ" description="๏ฟฝ๏ฟฝ๏ฟฝำท๏ฟฝฤผ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝสผ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝฦทหผ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ">
  <BlogIndexPage lang="zh" posts={posts} />
</BaseLayout>