---
import { contactLinks } from "../data/site";
import SocialIcon from "./SocialIcon.astro";

interface Props {
  lang: "en" | "zh";
}

const { lang } = Astro.props;
const labels = {
  title: lang === "en" ? "Contact" : "联系",
  intro:
    lang === "en"
      ? "Reach me through these channels for collaboration, product discussions, and career opportunities."
      : "如果你希望合作、交流产品思路或工作机会，可以通过以下方式联系我。"
};
---
<section class="section">
  <div class="container contact-grid">
    <div class="left">
      <h1 class="section-title">{labels.title}</h1>
      <p>{labels.intro}</p>
    </div>

    <div class="right">
      {contactLinks.map((item) => (
        <a class="contact-link" href={item.href} target={item.label === "Email" ? undefined : "_blank"} rel="noreferrer">
          <span class="contact-main">
            <span class="icon-shell"><SocialIcon name={item.label as "LinkedIn" | "GitHub" | "CSDN" | "Email"} /></span>
            <span>{item.label}</span>
          </span>
          <span class="contact-arrow" aria-hidden="true">↗</span>
        </a>
      ))}
    </div>
  </div>
</section>
