---
interface Props {
  name: "LinkedIn" | "GitHub" | "CSDN" | "Email";
}

const { name } = Astro.props;
---
{
  name === "LinkedIn" && (
    <svg viewBox="0 0 24 24" aria-hidden="true">
      <rect x="3" y="8" width="4" height="12"></rect>
      <circle cx="5" cy="5" r="2"></circle>
      <path d="M10 8h4v2.2c.7-1.4 2-2.5 4-2.5 3 0 4 1.9 4 5.3V20h-4v-5.9c0-1.7-.6-2.8-2.1-2.8-1.3 0-1.9.9-2.2 1.7-.1.3-.1.7-.1 1V20h-4z"></path>
    </svg>
  )
}
{
  name === "GitHub" && (
    <svg viewBox="0 0 24 24" aria-hidden="true">
      <path d="M12 2a10 10 0 0 0-3.2 19.5c.5.1.7-.2.7-.5v-2c-2.9.6-3.5-1.2-3.5-1.2-.4-1-1-1.3-1-1.3-.8-.5.1-.5.1-.5.9.1 1.4.9 1.4.9.8 1.4 2.2 1 2.7.8.1-.6.3-1 .6-1.2-2.3-.2-4.8-1.1-4.8-5A3.9 3.9 0 0 1 6 8.3c-.1-.3-.4-1.3.1-2.8 0 0 .8-.3 2.8 1a9.6 9.6 0 0 1 5.2 0c2-1.3 2.8-1 2.8-1 .6 1.5.2 2.5.1 2.8a3.9 3.9 0 0 1 1 2.7c0 3.9-2.5 4.8-4.8 5 .3.2.7.8.7 1.7v2.4c0 .3.2.6.7.5A10 10 0 0 0 12 2z"></path>
    </svg>
  )
}
{
  name === "CSDN" && (
    <svg viewBox="0 0 24 24" aria-hidden="true">
      <path d="M4 6h10v3H7v2h6v3H7v2h7v3H4z"></path>
      <path d="M20 6h-5v3h4v8h-4v3h5a2 2 0 0 0 2-2V8a2 2 0 0 0-2-2z"></path>
    </svg>
  )
}
{
  name === "Email" && (
    <svg viewBox="0 0 24 24" aria-hidden="true">
      <rect x="3" y="6" width="18" height="12" fill="none" stroke="currentColor" stroke-width="1.8"></rect>
      <path d="M4 7l8 6 8-6" fill="none" stroke="currentColor" stroke-width="1.8"></path>
    </svg>
  )
}
