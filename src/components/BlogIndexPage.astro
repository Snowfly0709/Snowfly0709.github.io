---
import type { CollectionEntry } from "astro:content";
import PostCard from "./PostCard.astro";

interface Props {
  lang: "en" | "zh";
  posts: CollectionEntry<"blog">[];
}

const { lang, posts } = Astro.props;

const labels = {
  title: lang === "en" ? "Blog" : "博客",
  search: lang === "en" ? "Search posts..." : "搜索文章...",
  tags: lang === "en" ? "Tags" : "标签",
  all: lang === "en" ? "All" : "全部",
  empty: lang === "en" ? "No posts match your filters." : "没有符合条件的文章。",
  rss: lang === "en" ? "RSS" : "订阅"
};

const tagSet = new Set<string>();
for (const post of posts) {
  for (const tag of post.data.tags) {
    tagSet.add(tag);
  }
}

const tags = [...tagSet].sort((a, b) => a.localeCompare(b));
---
<section class="section">
  <div class="container">
    <div class="blog-title-row">
      <h1 class="section-title">{labels.title}</h1>
      <a class="rss-link" href={lang === "en" ? "/en/rss.xml" : "/zh/rss.xml"}>{labels.rss}</a>
    </div>

    <div class="blog-layout">
      <aside class="blog-sidebar">
        <input class="search-input" type="search" placeholder={labels.search} data-search-input />

        <p class="meta-line" style="margin:0 0 8px;">{labels.tags}</p>
        <div class="tag-list" data-tag-list>
          <button class="tag-btn active" data-tag="all">{labels.all}</button>
          {tags.map((tag) => (
            <button class="tag-btn" data-tag={tag.toLowerCase()}>{tag}</button>
          ))}
        </div>
      </aside>

      <div class="blog-list" data-post-list>
        {posts.map((post) => (
          <PostCard post={post} />
        ))}
        <div class="empty-state" data-empty hidden>{labels.empty}</div>
      </div>
    </div>
  </div>
</section>

<script>
  const input = document.querySelector("[data-search-input]");
  const tagList = document.querySelector("[data-tag-list]");
  const cards = [...document.querySelectorAll("[data-post-card]")];
  const empty = document.querySelector("[data-empty]");

  let activeTag = "all";

  const applyFilter = () => {
    const q = (input?.value || "").trim().toLowerCase();
    let visible = 0;

    for (const card of cards) {
      const tags = card.getAttribute("data-tags") || "";
      const title = card.getAttribute("data-title") || "";
      const desc = card.getAttribute("data-desc") || "";
      const body = card.getAttribute("data-body") || "";

      const tagMatch = activeTag === "all" || tags.includes(activeTag);
      const text = `${title} ${desc} ${body} ${tags}`;
      const searchMatch = q.length === 0 || text.includes(q);

      const show = tagMatch && searchMatch;
      card.hidden = !show;
      if (show) visible += 1;
    }

    if (empty) empty.hidden = visible !== 0;
  };

  input?.addEventListener("input", applyFilter);

  tagList?.addEventListener("click", (event) => {
    const target = event.target;
    if (!(target instanceof HTMLButtonElement)) return;

    const tag = target.dataset.tag;
    if (!tag) return;

    activeTag = tag;
    for (const btn of tagList.querySelectorAll(".tag-btn")) {
      btn.classList.toggle("active", btn === target);
    }

    applyFilter();
  });

  applyFilter();
</script>
