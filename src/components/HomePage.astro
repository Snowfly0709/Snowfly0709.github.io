---
import Hero from "./Hero.astro";
import { aboutSections, skills } from "../data/site";

interface Props {
  lang: "en" | "zh";
}

const { lang } = Astro.props;
const about = aboutSections[lang];

const labels = {
  about: lang === "en" ? "About" : "关于",
  experience: lang === "en" ? "Experience" : "工作经历",
  projects: lang === "en" ? "Projects" : "项目经历",
  education: lang === "en" ? "Education" : "教育经历",
  publications: lang === "en" ? "Publications" : "出版作品",
  skills: lang === "en" ? "Skill Cloud" : "技能云图",
  contact: lang === "en" ? "Go To Contact" : "前往联系",
  laneHint: lang === "en" ? "Latest to Earlier" : "从新到旧"
};

const cloudMap = [
  { x: 8, y: 8, s: 0.94, d: 0.2 },
  { x: 36, y: 12, s: 1.04, d: 0.8 },
  { x: 63, y: 10, s: 1.0, d: 1.3 },
  { x: 12, y: 28, s: 0.96, d: 1.1 },
  { x: 40, y: 30, s: 0.92, d: 0.4 },
  { x: 70, y: 29, s: 1.1, d: 1.5 },
  { x: 5, y: 46, s: 1.05, d: 0.5 },
  { x: 28, y: 49, s: 0.94, d: 0.7 },
  { x: 49, y: 48, s: 1.09, d: 0.9 },
  { x: 76, y: 46, s: 0.98, d: 1.6 },
  { x: 15, y: 65, s: 1.0, d: 0.3 },
  { x: 44, y: 68, s: 0.96, d: 1.2 },
  { x: 66, y: 66, s: 1.03, d: 0.6 },
  { x: 4, y: 82, s: 0.93, d: 1.5 },
  { x: 30, y: 84, s: 1.12, d: 0.8 },
  { x: 55, y: 84, s: 0.94, d: 0.2 },
  { x: 74, y: 82, s: 1.06, d: 1.1 },
  { x: 43, y: 4, s: 0.9, d: 0.45 }
] as const;
---
<Hero lang={lang} />

<section id="about" class="section">
  <div class="container">
    <h2 class="section-title">{labels.about}</h2>

    <div class="grid-12">
      <article class="about-intro panel-card">
        <p>{about.intro}</p>
      </article>

      <aside class="profile-panel panel-card">
        <div class="profile-photo-box">
          <img src="/images/profile.png" alt="Portrait of Zifeng Xiong" loading="lazy" width="820" height="1200" />
        </div>
        <p>Zifeng Xiong</p>
      </aside>

      <section class="project-lane panel-card">
        <div class="lane-head">
          <h3 class="subsection-title">{labels.projects}</h3>
          <span class="lane-hint">{labels.laneHint}</span>
        </div>

        <div class="project-track">
          {about.projects.map((item, idx) => (
            <article class="project-card">
              <div class="project-card-head">
                <span class="project-index">{String(idx + 1).padStart(2, "0")}</span>
                <span class="project-arrow" aria-hidden="true">→</span>
              </div>
              <h4>{item.name}</h4>
              <p class="meta-line">{item.period}</p>
              <p>{item.detail}</p>
            </article>
          ))}
        </div>
      </section>

      <div class="timeline">
        <section class="panel-card info-block">
          <h3 class="subsection-title">{labels.experience}</h3>
          {about.work.map((item) => (
            <article class="timeline-item">
              <h3>{item.title}</h3>
              <p class="meta-line">{item.org} | {item.period}</p>
              <p>{item.detail}</p>
            </article>
          ))}
        </section>

        <section class="panel-card info-block">
          <h3 class="subsection-title">{labels.education}</h3>
          {about.education.map((item) => (
            <article class="timeline-item">
              <h3>{item.school}</h3>
              <p class="meta-line">{item.degree} | {item.period}</p>
              <p>{item.location}</p>
            </article>
          ))}
        </section>

        <section class="panel-card info-block">
          <h3 class="subsection-title">{labels.publications}</h3>
          {about.publications.map((item) => (
            <article class="timeline-item">
              <p>{item}</p>
            </article>
          ))}
        </section>
      </div>

      <section class="skill-cloud-wrap panel-card">
        <h3 class="subsection-title">{labels.skills}</h3>
        <div class="skill-cloud" aria-label={labels.skills}>
          {skills.map((skill, idx) => {
            const cfg = cloudMap[idx % cloudMap.length];
            return (
              <span
                class="skill-chip cloud-chip"
                style={`--x:${cfg.x}%;--y:${cfg.y}%;--scale:${cfg.s};--delay:${cfg.d}s;`}
              >
                {skill}
              </span>
            );
          })}
        </div>
      </section>
    </div>
  </div>
</section>

<section class="section section-cta">
  <div class="container">
    <a class="btn primary" href={lang === "en" ? "/en/contact/" : "/zh/contact/"}>{labels.contact}</a>
  </div>
</section>
