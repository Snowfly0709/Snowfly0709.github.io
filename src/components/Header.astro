---
import { navItems } from "../data/site";

interface Props {
  lang: "en" | "zh";
}

const { lang } = Astro.props;
const pathname = Astro.url.pathname;
const nav = navItems[lang];

const targetPath = lang === "en" ? pathname.replace(/^\/en/, "/zh") || "/zh/" : pathname.replace(/^\/zh/, "/en") || "/en/";
const altLang = lang === "en" ? "ZH" : "EN";
---
<header class="site-header">
  <div class="container inner">
    <a href={lang === "en" ? "/en/" : "/zh/"} class="brand">Zifeng Xiong<span class="dot">.</span></a>
    <button class="mobile-toggle" data-nav-toggle>{lang === "en" ? "Menu" : "�˵�"}</button>
    <div class="nav-wrap" data-nav-wrap>
      <nav class="nav-links" aria-label="Main navigation">
        {nav.map((item) => (
          <a href={item.href}>{item.label}</a>
        ))}
      </nav>
      <div class="lang-switch" aria-label="Language switcher">
        <a href={targetPath} class="active">{altLang}</a>
      </div>
    </div>
  </div>
</header>

<script>
  const toggle = document.querySelector("[data-nav-toggle]");
  const wrap = document.querySelector("[data-nav-wrap]");

  if (toggle && wrap) {
    toggle.addEventListener("click", () => {
      wrap.classList.toggle("open");
    });
  }
</script>